# Публичный домен Railway (обязательно после первого деплоя)
# Пример: my-vpn-production.up.railway.app
VPN_DOMAIN=

# Пароль Shadowsocks (если пусто — сгенерируется автоматически)
VPN_SECRET=

# Секретный путь WebSocket (если пусто — сгенерируется автоматически)
WS_PATH=

# Часть URL для ssconf://домен/ПРЕФИКС/UUID
KEY_PREFIX=vanya

# UUID в ссылке (если пусто — сгенерируется автоматически)
KEY_UUID=
